# ─── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/myweb_dev?schema=public"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=change_me_access_secret_very_long_and_random
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_and_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4200

# Admin seed (first run only)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Your Name

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── WEB (Angular) ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1

# ─── UPLOADS ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
